# GPS Issue & Management Center — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# -- LLM (spec §6.3, §14.4) --
# Anthropic API key. Set Billing Alert in Anthropic console (monthly cap + daily reminder).
ANTHROPIC_API_KEY=
# Pinned model identifier per §14.4 — do NOT use `-latest` aliases in production.
# Bump via ADR + dev-environment ground-truth regression test before changing here.
LLM_MODEL_ID=claude-sonnet-4-20250514
# Reserved for Phase 3 IT decision: "anthropic" | "bedrock" | "vertex"
LLM_PROVIDER=anthropic

# -- Database (spec §6.4) --
# Postgres connection string (Supabase or Neon in Phase 1-2; TSMC internal in Phase 3).
DATABASE_URL=postgresql://user:pass@localhost:5432/gps_issue_center
# Direct (unpooled) connection — used by Prisma migrations.
DIRECT_URL=postgresql://user:pass@localhost:5432/gps_issue_center

# -- Auth (spec §6.5) --
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -- Sources (spec §8 Phase 1) --
NEWSAPI_KEY=
ACLED_EMAIL=
ACLED_KEY=

# -- Alerts (spec §6.5) --
RESEND_API_KEY=
ALERT_EMAIL_TO=rockie@example.com
ALERT_EMAIL_FROM=alerts@example.com

# -- Cron auth (Vercel Cron) --
CRON_SECRET=

# -- Budget circuit-breaker (spec §9.2) --
# Monthly USD cap. Daily budget computed as: MONTHLY_BUDGET_USD * 1.1 / 30
MONTHLY_BUDGET_USD=500
